    senior_resignations_by_year=senior_res,
    junior_resignations_by_year=junior_res,
    seed=seed,
)

df_legacy, events_legacy, restructuring_month, year_zero_cost = run_salary_sim(**common, legacy_mode=True)
df_pipeline, _, _, _                                              = run_salary_sim(**common, legacy_mode=False)

# Chart dataframes exclude the Year 0 pre-snapshot (month -1)
df_legacy_chart   = df_legacy[df_legacy["month"] >= 0].copy()
df_pipeline_chart = df_pipeline[df_pipeline["month"] >= 0].copy()

# Apply 3-month rolling average to smooth month-to-month noise for charts
window = 3
for col in ["total_cost", "senior_ii_cost", "senior_cost", "junior_cost"]:
    df_legacy_chart[f"{col}_smooth"]   = df_legacy_chart[col].rolling(window, center=True, min_periods=1).mean()
    df_pipeline_chart[f"{col}_smooth"] = df_pipeline_chart[col].rolling(window, center=True, min_periods=1).mean()

# ── Year-over-year savings table ──────────────────────────────────────────────

st.subheader("Year-over-Year Cost Summary")

# Use exact month 11, 23, 35... for end-of-year values (unsmoothed)
def get_year_end_cost(df, year):
    end_month = year * 12 - 1  # month 11 = end of year 1, etc.
    row = df[df["month"] == end_month]
    return row["total_cost"].values[0] if len(row) > 0 else None

summary_rows = []
base_cost = year_zero_cost
prev_cost = base_cost

# Year 0 — pre-promotion baseline
summary_rows.append({
    "Year": "Now (Year 0)",
    "Year-End Salary Bill": f"${base_cost:,.0f}",
    "Change from Prior Year ($)": "—",
    "Change from Prior Year (%)": "—",
    "Change from Year 0 ($)": "—",
    "Change from Year 0 (%)": "—",
})

for y in range(1, sim_years + 1):
    lc = get_year_end_cost(df_legacy, y)
    if lc is None:
        continue
    yoy_change = lc - prev_cost
    yoy_pct    = (yoy_change / prev_cost * 100) if prev_cost > 0 else 0
    cum_change = lc - base_cost
    cum_pct    = (cum_change / base_cost * 100) if base_cost > 0 else 0
    summary_rows.append({
        "Year": f"Year {y}",
        "Year-End Salary Bill": f"${lc:,.0f}",
        "Change from Prior Year ($)": f"${yoy_change:+,.0f}",
        "Change from Prior Year (%)": f"{yoy_pct:+.1f}%",
        "Change from Year 0 ($)": f"${cum_change:+,.0f}",
        "Change from Year 0 (%)": f"{cum_pct:+.1f}%",
    })
    prev_cost = lc

summary_df = pd.DataFrame(summary_rows)
st.dataframe(summary_df, use_container_width=True, hide_index=True)

if restructuring_month:
